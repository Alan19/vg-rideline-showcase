---
import {type CollectionEntry, getCollection} from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import {doesDeckHavePricingGuide, pricingGuide,} from "../../../pricing.ts";
import {PricingTable} from "../../../layouts/PricingTable.tsx";
import {ThemeSwitcher} from "../../../components/ThemeSwitcher.tsx";
import Image from "astro/components/Image.astro";

import './pricing.css'

import '../../../styles/showcase.css'
type Props = CollectionEntry<'decks'>;
const post = Astro.props;
const pricing = pricingGuide[post.id]

export async function getStaticPaths() {
    const posts = await getCollection('decks');
    return posts.filter(value => doesDeckHavePricingGuide(value.id)).map(post => ({
        params: {slug: post.id},
        props: post,
    }));
}
---
<Layout title={post.data.title + " - Pricing"}>
    <ThemeSwitcher client:only="react" nation={post.data.nation}/>
    <!--Using bootleg main component to make sticky work-->
    <div class="grid responsive" style="max-inline-size: min(100vw, 75rem);  margin: 0 auto; padding: .5rem">
        <div class="l3 m2 s12 sticky-image">
            <Image widths={[500]} class="card-art" src={post.data['card-art']} alt={post.data.title} transition:name={`img_${post.data.title}`} slot="card-art"/>
        </div>
        <div class="l9 m10 s12">
            <PricingTable deckPricing={pricing} title={post.data.title}/>
        </div>
    </div>
</Layout>
