---
import {type CollectionEntry, getCollection, render} from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import {DeckShowcase} from '../../layouts/DeckShowcase.tsx';
import Image from 'astro/components/Image.astro';
import ImageCollectionWithPopover from "../../components/ImageCollectionWithPopover.astro";
import {getPricingNumbers, getPricingTier, PricingCategory, pricingGuide} from "../../pricing.ts";

export async function getStaticPaths() {
    const posts = await getCollection('decks');
    return posts.map((post) => ({
        params: {slug: post.id},
        props: post,
    }));
}
type Props = CollectionEntry<'decks'>;

const post = Astro.props;
const {Content} = await render(post);
const pricing = getPricingNumbers(pricingGuide[post.id])
const pricingTiers = {
    core: getPricingTier(pricing.coreCardCosts, PricingCategory.CORE),
    generics: getPricingTier(pricing.genericCardCosts, PricingCategory.GENERICS),
    total: getPricingTier(pricing.total, PricingCategory.TOTAL)
}
---
<Layout {...post.data}>
    <DeckShowcase {...post.data} coreCostTier={pricingTiers.core} genericsCostTier={pricingTiers.generics} totalCostTier={pricingTiers.total}>
        <Image widths={[500]} class="card-art" src={post.data['card-art']} alt={post.data.title} transition:name={`img_${post.data.title}`} slot="card-art"/>
        <Content slot="content"/>
        <ImageCollectionWithPopover slot="ridelineCardImages" images={post.data.rideline} category="ridelineCardImages"/>
        <ImageCollectionWithPopover slot="keyCardImages" images={post.data["key-cards"]} category="keyCardImages"/>
        <ImageCollectionWithPopover slot="genericCardImages" images={post.data.generics} category="genericCardImages"/>
    </DeckShowcase>
</Layout>
