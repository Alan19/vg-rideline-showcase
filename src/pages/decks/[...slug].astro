---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import {DeckShowcase} from '../../layouts/DeckShowcase.tsx';
import {Picture} from "astro:assets";
import {getImage} from "astro/assets";

export async function getStaticPaths() {
	const posts = await getCollection('decks');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'decks'>;

const post = Astro.props;
const { Content } = await render(post);

---
<Layout {...post.data}>
	<DeckShowcase {...post.data}>
		<Picture class="card-art" src={post.data['card-art']} alt={post.data.title} transition:name={`img_${post.data.title}`} slot="card-art"/>
		<Content slot="content" />
	</DeckShowcase>
</Layout>
